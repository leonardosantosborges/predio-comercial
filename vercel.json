{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "source": "/admin",
      "dest": "/admin.html"
    },
    {
      "source": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff"
      },
      "dest": "/$1"
    }
  ]
}
